{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "non-streaming-speech-recognition-from-microphone",
  "version": "1.13.0",
  "identifier": "com.k2fsa.sherpa.onnx.asr.microphone",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sherpa-onnx Speech Recognition from microphone",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": ["assets"]
  }
}
